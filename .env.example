# PRC Group — environment variables
# Set these in Coolify (Application -> Environment Variables). Do NOT commit real values.

# Where lead/booking emails are delivered
LEAD_EMAIL=info@prcgroupcompany.com

# From address (must be on your domain / authorized by the SMTP provider)
SMTP_FROM=no-reply@prcgroupcompany.com

# SMTP server. Leave SMTP_HOST empty to fall back to PHP mail().
#   tls -> port 587 (STARTTLS)   |   ssl -> port 465
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# --- Provider examples ---------------------------------------------------
# Gmail (needs an App Password, not your login password):
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=tls
#   SMTP_USER=you@gmail.com   SMTP_PASS=<16-char app password>
#
# SendGrid:
#   SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_SECURE=tls
#   SMTP_USER=apikey             SMTP_PASS=<your SendGrid API key>
#
# Mailgun:
#   SMTP_HOST=smtp.mailgun.org   SMTP_PORT=587  SMTP_SECURE=tls
#   SMTP_USER=postmaster@mg.yourdomain.com  SMTP_PASS=<smtp password>
